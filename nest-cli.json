{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/learn-kafkah/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/learn-kafkah/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/learn-kafkah",
  "projects": {
    "course-service": {
      "type": "application",
      "root": "apps/course-service",
      "entryFile": "main",
      "sourceRoot": "apps/course-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/course-service/tsconfig.app.json"
      }
    },
    "learn-kafkah": {
      "type": "application",
      "root": "apps/learn-kafkah",
      "entryFile": "main",
      "sourceRoot": "apps/learn-kafkah/src",
      "compilerOptions": {
        "tsConfigPath": "apps/learn-kafkah/tsconfig.app.json"
      }
    },
    "orders-api-service": {
      "type": "application",
      "root": "apps/orders-api-service",
      "entryFile": "main",
      "sourceRoot": "apps/orders-api-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/orders-api-service/tsconfig.app.json"
      }
    },
    "payment-service": {
      "type": "application",
      "root": "apps/payment-service",
      "entryFile": "main",
      "sourceRoot": "apps/payment-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/payment-service/tsconfig.app.json"
      }
    }
  }
}